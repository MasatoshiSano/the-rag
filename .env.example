# AWS 認証情報（Bedrock を使う場合は必須。docker-compose は env_file で .env を読み込む）。
# STS 一時クレデンシャルを使う場合は AWS_SESSION_TOKEN も設定する。
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=ap-northeast-1

# AWS Bedrock
BEDROCK_REGION=ap-northeast-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5
BEDROCK_EMBED_MODEL_ID=cohere.embed-multilingual-v3
BEDROCK_RERANK_MODEL_ID=cohere.rerank-v3-5

# Oracle DB (optional)
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_ENABLED=false

# Security
SECRET_KEY=change-this-to-a-random-secret-key

# 外部 API エンドポイント (/api/ext/*) の X-API-Key 認証用キー（カンマ区切り、任意）。
# API_KEYS=key1,key2

# Gitea 連携（任意）
GITEA_BASE_URL=
GITEA_TOKEN=

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
