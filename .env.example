# AWS Bedrock
BEDROCK_REGION=ap-northeast-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5
BEDROCK_EMBED_MODEL_ID=cohere.embed-multilingual-v3
BEDROCK_RERANK_MODEL_ID=cohere.rerank-v3-5

# Oracle DB (optional)
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_ENABLED=false

# Security
# 必須。ランダムな値を生成して設定する（例: python -c "import secrets; print(secrets.token_urlsafe(48))"）。
# 未設定または "dev-secret-key-change-in-production" のままだとバックエンドは起動しない。
SECRET_KEY=change-this-to-a-random-secret-key

# 外部 API エンドポイント (/api/external/*) の X-API-Key 認証用キー（JSON 配列形式）。
# 未設定なら外部 API は無効化される。"the-rag-default-key" を含めるとバックエンドは起動しない。
# API_KEYS=["your-random-api-key"]

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
