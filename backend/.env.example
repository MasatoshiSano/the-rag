# RAG Phantom バックエンド環境変数のサンプル設定
# このファイルを `.env` にコピーし、必要な値を設定してください。

# -----------------------------------------------------------------------------
# AWS Bedrock
# -----------------------------------------------------------------------------
BEDROCK_REGION=ap-northeast-1
BEDROCK_MODEL_ID=jp.anthropic.claude-sonnet-4-6
BEDROCK_EMBED_MODEL_ID=cohere.embed-multilingual-v3
BEDROCK_RERANK_MODEL_ID=cohere.rerank-v3-5:0

# -----------------------------------------------------------------------------
# Oracle DB (任意)
# -----------------------------------------------------------------------------
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_ENABLED=true

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=documents
QDRANT_MASTER_COLLECTION=master_data

# -----------------------------------------------------------------------------
# SQLite
# -----------------------------------------------------------------------------
SQLITE_DB_PATH=/app/data/ragphantom.db

# -----------------------------------------------------------------------------
# 外部 API キー
# -----------------------------------------------------------------------------
# /api/ext/* エンドポイント（外部システム連携用）の認証に使用するキーを
# カンマ区切りで列挙する。空のまま起動すると当該エンドポイントは
# すべて 403 を返すため、本番環境では必ず強力なランダム文字列を設定する。
#
# 生成例:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   openssl rand -base64 48
#
# 例: API_KEYS=your-strong-random-key-here
API_KEYS=

# -----------------------------------------------------------------------------
# セキュリティ
# -----------------------------------------------------------------------------
SECRET_KEY=dev-secret-key-change-in-production

# -----------------------------------------------------------------------------
# エージェンティック検索
# -----------------------------------------------------------------------------
AGENTIC_MAX_ITERATIONS=10
AGENTIC_LOOP_TIMEOUT=120  # 秒。タイムアウト時はSSEで error イベントを返す。

# -----------------------------------------------------------------------------
# Gitea 連携 (任意 - GitHub レート制限回避用のセカンダリソース)
# -----------------------------------------------------------------------------
GITEA_BASE_URL=
GITEA_TOKEN=
